<Window x:Class="ICSharpCode.AiAgent.TypewriterResultWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="AI Agent Result"
        WindowStartupLocation="CenterOwner"
        MinWidth="600"
        MinHeight="400"
        Width="800"
        Height="600">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <Grid Grid.Row="0" Margin="0 0 0 8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" x:Name="TitleText" Text="AI Agent Result" FontSize="14" FontWeight="Bold" VerticalAlignment="Center"/>
            <TextBlock Grid.Column="1" x:Name="ProgressText" Text="" FontSize="11" Foreground="Gray" VerticalAlignment="Center" Margin="0 0 8 0"/>
            <Button Grid.Column="2" x:Name="InsertButton" Content="Insert to Editor" Width="110" Height="26" Click="InsertButton_Click"/>
        </Grid>
        
        <Border Grid.Row="1" BorderBrush="#CCC" BorderThickness="1" CornerRadius="3">
            <ScrollViewer x:Name="ScrollViewer" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
                <TextBox x:Name="OutputTextBox"
                         IsReadOnly="True"
                         FontFamily="Consolas"
                         FontSize="12"
                         TextWrapping="NoWrap"
                         Padding="8"
                         BorderThickness="0"
                         Background="White"/>
            </ScrollViewer>
        </Border>
        
        <Grid Grid.Row="2" Margin="0 8 0 0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" x:Name="TypewriterStatus" Text="" FontSize="11" Foreground="Gray" VerticalAlignment="Center"/>
            <Button Grid.Column="1" x:Name="CopyButton" Content="Copy" Width="70" Height="26" Margin="0 0 8 0" Click="CopyButton_Click"/>
            <Button Grid.Column="2" Content="Close" Width="70" Height="26" IsCancel="True"/>
        </Grid>
    </Grid>
</Window>