<Window x:Class="ICSharpCode.AiAgent.ConfigurationDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="AI Agent Configuration"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        SizeToContent="WidthAndHeight"
        MinWidth="400"
        WindowStyle="ToolWindow">
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <TextBlock Grid.Row="0" Text="AI Agent Settings" FontSize="16" FontWeight="Bold" Margin="0 0 0 15"/>
        
        <Grid Grid.Row="1" Margin="0 0 0 10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="80"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="Provider:" VerticalAlignment="Center"/>
            <ComboBox Grid.Column="1" x:Name="ProviderComboBox" SelectedIndex="0" Height="28" SelectionChanged="ProviderComboBox_SelectionChanged">
                <ComboBoxItem Tag="OpenAI">OpenAI (GPT)</ComboBoxItem>
                <ComboBoxItem Tag="Anthropic">Anthropic (Claude)</ComboBoxItem>
            </ComboBox>
        </Grid>

        <Grid Grid.Row="2" Margin="0 0 0 5">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="80"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="Model:" VerticalAlignment="Center"/>
            <ComboBox Grid.Column="1" x:Name="ModelComboBox" Height="28"/>
        </Grid>
        
        <Grid Grid.Row="3" Margin="0 0 0 5">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="80"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="API Key:" VerticalAlignment="Center"/>
            <PasswordBox Grid.Column="1" x:Name="ApiKeyBox" Height="28"/>
        </Grid>
        
        <TextBlock Grid.Row="4" x:Name="StatusMessage" FontSize="11" Foreground="Gray" Margin="80 0 0 5"/>
        
        <Grid Grid.Row="5" Margin="0 10 0 0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <Button Grid.Column="1" x:Name="SaveButton" Content="Save" Width="80" Height="28" Margin="0 0 8 0" IsDefault="True" Click="SaveButton_Click"/>
            <Button Grid.Column="2" Content="Cancel" Width="80" Height="28" IsCancel="True"/>
        </Grid>
    </Grid>
</Window>